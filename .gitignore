# Agent workflow library: keep durable references/templates/scripts tracked.
# All local-only notes, scratch space, logs, machine-local state, and secrets
# live under .agent/local/ and stay ignored except for placeholder docs.
.agent/local/*
!.agent/local/README.md
!.agent/local/logs/
.agent/local/logs/*
!.agent/local/logs/.gitkeep
!.agent/local/notes/
.agent/local/notes/*
