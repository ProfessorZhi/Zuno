{
  "version": "phase04-contract-v1",
  "purpose": "Parser golden fixture index for Document Ingestion contract tests.",
  "cases": [
    {
      "case_id": "pdf_table",
      "format": "pdf",
      "input_path": "inputs/pdf_table.pdf",
      "default_parser": "docling_pymupdf",
      "fallback": "mineru_ocr_vlm",
      "evidence_anchor": ["page", "bbox", "table_cell"],
      "expected_blocks": ["paragraph", "table"]
    },
    {
      "case_id": "scanned_image",
      "format": "scanned",
      "input_path": "inputs/scanned_image.png",
      "default_parser": "mineru_ocr_vlm",
      "fallback": "docling_pymupdf",
      "evidence_anchor": ["page", "bbox", "confidence"],
      "expected_blocks": ["ocr_text", "figure"]
    },
    {
      "case_id": "pptx_slide",
      "format": "pptx",
      "input_path": "inputs/pptx_slide.pptx",
