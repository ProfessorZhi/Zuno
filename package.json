{
  "name": "zuno",
  "private": true,
  "version": "1.0.0",
  "description": "Local-first agent workspace with LangGraph, RAG, GraphRAG, MCP, knowledge bases, and desktop runtime.",
  "workspaces": [
    "apps/web",
    "apps/desktop"
  ],
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "frontend:dev": "npm run dev -w zuno-frontend",
    "frontend:build": "npm run build -w zuno-frontend",
    "frontend:lint": "npm run lint -w zuno-frontend",
    "desktop:dev": "npm run dev -w zuno-desktop",
    "desktop:start": "npm run start -w zuno-desktop"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProfessorZhi/Zuno.git"
  },
  "keywords": [
    "agent",
    "langgraph",
    "rag",
    "graphrag",
    "mcp",
    "fastapi",
    "electron",
    "vue"
  ],
  "author": "ProfessorZhi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ProfessorZhi/Zuno/issues"
  },
  "homepage": "https://github.com/ProfessorZhi/Zuno#readme"
}
